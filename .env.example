# Local NVIDIA NIM endpoint from the API reference examples.
ALCHEMI_BMD_BASE_URL=http://localhost:8000

# Optional. The client sends this as Authorization: Bearer <key> if present.
# Use whichever variable name is already standard in your environment.
NGC_API_KEY=
NVIDIA_API_KEY=
ALCHEMI_BMD_API_KEY=

# Request timeout in seconds.
ALCHEMI_BMD_TIMEOUT=120

# Optional Falsiflow public release readiness inputs.
FALSIFLOW_REPO_URL=
FALSIFLOW_PUBLIC_DEMO_URL=
FALSIFLOW_PIPX_VALIDATED=0
FALSIFLOW_WINDOWS_VALIDATED=0
